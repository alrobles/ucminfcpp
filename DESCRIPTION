Package: ucminfcpp
Type: Package
Title: C++ Reimplementation of the 'ucminf' Unconstrained Nonlinear Optimizer
Version: 0.1.0
Authors@R: c(
    person("Angel Luis", "Robles Fernández", 
           role = c("aut", "cre"),
           email = "a.l.robles.fernandez@gmail.com"),
    person("Hans Bruun", "Nielsen",
           role = "cph",
           comment = "Original UCMINF algorithm (Fortran)"),
